    "@repo/db": "workspace:*",
    "@repo/integrations-core": "workspace:*",
    "@repo/shared": "workspace:*",
    "better-auth": "^1.6.23",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.0",
    "jose": "^6.2.2",
    "resend": "^6.12.0",
