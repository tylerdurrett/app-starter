{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["WSL_DISTRO_NAME", "WSL_INTEROP", "WSLENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {}
  }
}
