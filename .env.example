# `pnpm hello` keeps compose mode, DB_PORT, and the local URL in sync.
DATABASE_MODE=compose
DB_PORT=5150
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5150/postgres

# To use a database not managed by this checkout, set DATABASE_MODE=external
# and provide its PostgreSQL URL. A custom URL alone never disables Compose.
# DATABASE_MODE=external
# DATABASE_URL=postgresql://user:password@database.example.com:5432/app

# Resend transactional email (password reset)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# In dev, `onboarding@resend.dev` only delivers to the Resend account owner.
# In prod, use an address on a domain verified in Resend (SPF/DKIM/DMARC).
EMAIL_FROM="App Starter <onboarding@resend.dev>"

# Integration Framework Configuration
# Encrypts integration credentials at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=<64-hex-chars; generate with: openssl rand -hex 32>

# API origin the browser uses to reach the server. For production this is your
# API domain, and for Tailscale HTTPS dev this is the machine MagicDNS name.
VITE_SERVER_URL=http://localhost:5100

# Frontend origin allowed to call the API with credentials. For production this
# is your static frontend domain. For Tailscale HTTPS dev, use the web port:
# https://<machine>.<tailnet>.ts.net:5200
CORS_ORIGIN=http://localhost:5200

# OAuth issuer/API origin. `pnpm hello` writes the localhost value. For MCP over
# Tailscale, replace this with your HTTPS MagicDNS API origin, e.g.
# https://<machine>.<tailnet>.ts.net
BETTER_AUTH_URL=http://localhost:5100
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>
# In production this defaults to true unless explicitly set to false.
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Forwarded request metadata is ignored by default. Set this only when the API
# is reachable exclusively through a trusted proxy; see docs/proxy-trust.md.
# Tailscale Serve: loopback. Standard Render web service: 1.
TRUST_PROXY=false

# Canonical MCP connector URL. For Tailscale, use:
# https://<machine>.<tailnet>.ts.net/mcp
MCP_CANONICAL_URL=http://localhost:5100/mcp

# Optional: allow Vite to answer the Tailscale MagicDNS host in dev.
VITE_ALLOWED_HOSTS=
